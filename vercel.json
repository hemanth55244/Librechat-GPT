{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "npm run frontend",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://librechat-gpt.onrender.com/api/:path*"
    },
    {
      "source": "/oauth/:path*",
      "destination": "https://librechat-gpt.onrender.com/oauth/:path*"
    },
    {
      "source": "/health",
      "destination": "https://librechat-gpt.onrender.com/health"
    },
    {
      "source": "/((?!assets/|images/|manifest.webmanifest|sw.js|sw-heal.js|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
