# Production template only. Do not put real secrets in git.

APP_NAME=LibreChat
APP_TITLE=LibreChat
APP_BRAND_NAME=LibreChat

HOST=0.0.0.0
PORT=3080

# Vercel + Render example domains. Replace with your real deployment URLs.
DOMAIN_CLIENT=https://librechat-gpt.vercel.app
DOMAIN_SERVER=https://librechat-gpt.onrender.com
ADMIN_PANEL_URL=https://admin.your-domain.com
ADMIN_PANEL_PORT=3000
ADMIN_PANEL_SESSION_COOKIE_SECURE=true

# For Docker Compose, use mongodb://mongodb:27017/LibreChat.
# For Render production, use MongoDB Atlas and keep the real value in Render env vars.
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/LibreChat?retryWrites=true&w=majority

# RAG API. For Render, use the rag_api service URL from render.yaml.
MEILI_HOST=
RAG_API_URL=https://librechat-rag-for-own.onrender.com

# rag_api service settings. Keep real values in Render, not GitHub.
VECTOR_DB_TYPE=atlas-mongo
ATLAS_MONGO_DB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/LibreChat?retryWrites=true&w=majority
ATLAS_SEARCH_INDEX=vector_index
COLLECTION_NAME=rag_chunks
EMBEDDINGS_PROVIDER=google_genai
EMBEDDINGS_MODEL=gemini-embedding-001
RAG_GOOGLE_API_KEY=replace_me

# Generate fresh production secrets:
#   openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars
JWT_REFRESH_SECRET=replace_with_64_hex_chars
CREDS_KEY=replace_with_64_hex_chars
MEILI_MASTER_KEY=replace_with_64_hex_chars
ADMIN_PANEL_SESSION_SECRET=replace_with_64_hex_chars

# Generate with:
#   openssl rand -hex 16
CREDS_IV=replace_with_32_hex_chars

# Provider keys. Rotate any key that was ever shared, committed, or pasted.
# Use GROQ_API_KEY for the Groq endpoint configured in config/librechat.render.yaml.
OPENAI_API_KEY=replace_me
GROQ_API_KEY=replace_me

ALLOW_EMAIL_LOGIN=true
ALLOW_UNVERIFIED_EMAIL_LOGIN=false
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=true
ALLOW_SOCIAL_REGISTRATION=true

GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_CALLBACK_URL=/oauth/google/callback

GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ENCRYPTION=starttls
EMAIL_USERNAME=replace_me
EMAIL_PASSWORD=replace_me
EMAIL_FROM_NAME=LibreChat
EMAIL_FROM=replace_me
